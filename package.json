{
  "name": "memlane",
  "version": "0.1.0",
  "description": "Memlane — a second brain for AI agents. MCP server that gives memoryless agents durable, queryable memory across sessions: structured state, knowledge-graph entities as markdown files, and one-call cold-start orientation.",
  "type": "module",
  "bin": {
    "memlane": "./dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "security:scan": "node scripts/security-scan.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "overrides": {
    "express-rate-limit": {
      "ip-address": "10.2.0"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
